{
  "name": "@giulio-leone/one-agent",
  "version": "0.15.1",
  "type": "module",
  "description": "OneAgent SDK 4.2 - AI agent framework with durable streaming, skill visibility, and weighted progress",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./framework": {
      "import": {
        "types": "./dist/framework/index.d.ts",
        "default": "./dist/framework/index.js"
      },
      "require": {
        "types": "./dist/framework/index.d.cts",
        "default": "./dist/framework/index.cjs"
      }
    },
    "./framework/engine": {
      "import": {
        "types": "./src/framework/engine.ts",
        "default": "./src/framework/engine.ts"
      },
      "require": {
        "types": "./src/framework/engine.ts",
        "default": "./src/framework/engine.ts"
      }
    },
    "./framework/persistence": {
      "import": {
        "types": "./src/framework/persistence.ts",
        "default": "./src/framework/persistence.ts"
      },
      "require": {
        "types": "./src/framework/persistence.ts",
        "default": "./src/framework/persistence.ts"
      }
    },
    "./adapters/*": {
      "import": {
        "types": "./dist/adapters/*.d.ts",
        "default": "./dist/adapters/*.js"
      },
      "require": {
        "types": "./dist/adapters/*.d.cts",
        "default": "./dist/adapters/*.cjs"
      }
    },
    "./core/*": {
      "import": {
        "types": "./dist/core/*.d.ts",
        "default": "./dist/core/*.js"
      },
      "require": {
        "types": "./dist/core/*.d.cts",
        "default": "./dist/core/*.cjs"
      }
    },
    "./agents/*": {
      "import": {
        "types": "./dist/agents/*.d.ts",
        "default": "./dist/agents/*.js"
      },
      "require": {
        "types": "./dist/agents/*.d.cts",
        "default": "./dist/agents/*.cjs"
      }
    },
    "./mesh/*": {
      "import": {
        "types": "./dist/mesh/*.d.ts",
        "default": "./dist/mesh/*.js"
      },
      "require": {
        "types": "./dist/mesh/*.d.cts",
        "default": "./dist/mesh/*.cjs"
      }
    },
    "./registry/*": {
      "import": {
        "types": "./dist/registry/*.d.ts",
        "default": "./dist/registry/*.js"
      },
      "require": {
        "types": "./dist/registry/*.d.cts",
        "default": "./dist/registry/*.cjs"
      }
    },
    "./schemas/*": {
      "import": {
        "types": "./dist/schemas/*.d.ts",
        "default": "./dist/schemas/*.js"
      },
      "require": {
        "types": "./dist/schemas/*.d.cts",
        "default": "./dist/schemas/*.cjs"
      }
    },
    "./utils/*": {
      "import": {
        "types": "./dist/utils/*.d.ts",
        "default": "./dist/utils/*.js"
      },
      "require": {
        "types": "./dist/utils/*.d.cts",
        "default": "./dist/utils/*.cjs"
      }
    },
    "./sdk-agents/*": {
      "import": {
        "types": "./dist/sdk-agents/*/index.d.ts",
        "default": "./dist/sdk-agents/*/index.js"
      },
      "require": {
        "types": "./dist/sdk-agents/*/index.d.cts",
        "default": "./dist/sdk-agents/*/index.cjs"
      }
    },
    "./api": {
      "import": {
        "types": "./dist/framework/api.d.ts",
        "default": "./dist/framework/api.js"
      },
      "require": {
        "types": "./dist/framework/api.d.cts",
        "default": "./dist/framework/api.cjs"
      }
    },
    "./chat": {
      "types": "./src/chat/index.ts",
      "default": "./src/chat/index.ts"
    },
    "./chat/client": {
      "types": "./src/chat/client.ts",
      "default": "./src/chat/client.ts"
    },
    "./chat/types": {
      "types": "./src/chat/types.ts",
      "default": "./src/chat/types.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@giulio-leone/agent-contracts": "workspace:*",
    "@ai-sdk/anthropic": "3.0.39",
    "@ai-sdk/openai": "3.0.26",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@giulio-leone/constants": "^0.13.0",
    "@giulio-leone/oneagenda-core": "workspace:*",
    "@giulio-leone/lib-ai": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@openrouter/ai-sdk-provider": "6.0.0-alpha.1",
    "@prisma/client": "^7.2.0",
    "@workflow/core": "4.0.1-beta.36",
    "@workflow/ai": "4.0.1-beta.44",
    "ai": "6.0.77",
    "yaml": "^2.8.2",
    "zod": "4.3.6",
    "@giulio-leone/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "zod": "^4.3.5",
    "@workflow/world-postgres": "4.1.0-beta.27"
  },
  "peerDependenciesMeta": {
    "@workflow/world-postgres": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
