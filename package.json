{
  "name": "@giulio-leone/one-agent",
  "version": "0.14.1",
  "description": "OneAgent - AI Agent framework",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./framework": {
      "types": "./dist/framework/index.d.ts",
      "import": "./dist/framework/index.js",
      "require": "./dist/framework/index.cjs"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    },
    "./chat": {
      "types": "./src/chat/index.ts",
      "import": "./dist/chat/index.js",
      "require": "./dist/chat/index.cjs",
      "default": "./src/chat/index.ts"
    },
    "./chat/client": {
      "types": "./src/chat/client.ts",
      "import": "./dist/chat/client.js",
      "require": "./dist/chat/client.cjs",
      "default": "./src/chat/client.ts"
    },
    "./chat/types": {
      "types": "./src/chat/types/index.ts",
      "import": "./dist/chat/types.js",
      "require": "./dist/chat/types.cjs",
      "default": "./src/chat/types/index.ts"
    },
    "./chat/hooks": {
      "types": "./src/chat/hooks/index.ts",
      "import": "./dist/chat/hooks.js",
      "require": "./dist/chat/hooks.cjs",
      "default": "./src/chat/hooks/index.ts"
    },
    "./chat/components": {
      "types": "./src/chat/components/index.ts",
      "import": "./dist/chat/components.js",
      "require": "./dist/chat/components.cjs",
      "default": "./src/chat/components/index.ts"
    },
    "./chat/utils": {
      "types": "./src/chat/utils/index.ts",
      "import": "./dist/chat/utils.js",
      "require": "./dist/chat/utils.cjs",
      "default": "./src/chat/utils/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/g97iulio1609/one-agent.git"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.39",
    "@ai-sdk/openai": "3.0.26",
    "@giulio-leone/gaussflow-agent": "latest",
    "@giulio-leone/lib-ai": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openrouter/ai-sdk-provider": "6.0.0-alpha.1",
    "ai": "6.0.77",
    "yaml": "^2.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@giulio-leone/one-flight": "workspace:*",
    "@giulio-leone/one-nutrition": "workspace:*",
    "@giulio-leone/one-workout": "workspace:*",
    "@prisma/client": "^7.2.0",
    "zod": "^4.3.5",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@giulio-leone/one-flight": {
      "optional": true
    },
    "@giulio-leone/one-nutrition": {
      "optional": true
    },
    "@giulio-leone/one-workout": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    }
  }
}
